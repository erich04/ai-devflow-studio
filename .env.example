# DevFlow Studio self-hosted pilot configuration.
#
# Copy to .env for local Docker Compose runs. Do not commit real secrets.

POSTGRES_DB=devflow
POSTGRES_PASSWORD=devflow
POSTGRES_USER=postgres

DEVFLOW_API_PORT=4310
DEVFLOW_WEB_PORT=4311
DEVFLOW_REQUIRE_AUTH=false
DEVFLOW_ENABLE_DEMO_DATA=false
DEVFLOW_ENABLE_FAKE_RUNTIME=false
DEVFLOW_SESSION_SECRET=replace-this-with-a-long-random-string

# GitHub OAuth is optional for local development that uses authenticated sessions.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://127.0.0.1:4310/api/auth/github/callback
