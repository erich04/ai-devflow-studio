{
  "name": "@ai-devflow/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "node ../../scripts/dev-electron.mjs",
    "build": "vite build && corepack pnpm build:electron",
