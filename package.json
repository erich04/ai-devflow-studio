{
  "name": "ai-devflow-studio",
  "version": "0.1.0",
  "private": true,
  "description": "Team AI development workflow platform with an Electron developer client.",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "corepack pnpm --parallel --filter @ai-devflow/desktop --filter @ai-devflow/api --filter @ai-devflow/web dev",
    "dev:desktop": "corepack pnpm --filter @ai-devflow/desktop dev",
    "dev:electron": "corepack pnpm --filter @ai-devflow/desktop dev:electron",
    "dev:web": "corepack pnpm --filter @ai-devflow/web dev",
    "dev:api": "corepack pnpm --filter @ai-devflow/api dev",
    "build": "corepack pnpm -r --if-present build",
    "typecheck": "corepack pnpm -r --if-present typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cross-platform": "node scripts/check-cross-platform.mjs",
    "test:postgres-smoke": "node scripts/postgres-smoke.mjs",
    "test:agent-live": "tsx scripts/agent-live-smoke.ts",
    "test:opencode-smoke": "tsx scripts/opencode-smoke.ts",
    "test:e2e": "node scripts/e2e.mjs",
    "test:electron-smoke": "node scripts/electron-smoke.mjs",
    "verify": "corepack pnpm typecheck && corepack pnpm test && corepack pnpm test:cross-platform && corepack pnpm test:e2e && corepack pnpm test:electron-smoke"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.10.1",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^5.1.1",
    "jsdom": "^26.1.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^3.2.4"
  }
}
